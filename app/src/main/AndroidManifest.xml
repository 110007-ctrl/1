<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:versionCode="54"
    android:versionName="v055v"> <!-- 54 for v055v -->

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SYSTEM_EXEMPTED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- https://developer.android.com/about/versions/13/behavior-changes-all#notification-permission -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Allows applications to change network connectivity state -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- WiFi state is used to detect network changes -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!--
        Fine and coarse location are required to read the connected WiFi SSID on
        Android 8.0–12 (API 26–32) so that SSID-based WireGuard rules can be applied.
        On Android 13+ (API 33+) WiFi SSID can be obtained via NetworkCapabilities /
        WifiInfo without any location permission.
    -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"
        android:maxSdkVersion="32" />

    <!--
        FIX #12 — ACCESS_BACKGROUND_LOCATION scope restriction.

        BEFORE: ACCESS_BACKGROUND_LOCATION was declared here (main manifest) with no
        maxSdkVersion, meaning every build flavor and every Android version requested it.
        This is overly broad because:
          (a) Android 13+ (API 33+) can read WiFi SSID via NetworkCapabilities without any
              location permission, so background location is completely unnecessary there.
          (b) Even on older versions, the VPN service runs as a foreground service (it
              shows a persistent system notification), so Android treats it as foreground
              and may not require the background location permission for SSID access.

        AFTER: ACCESS_BACKGROUND_LOCATION is moved to the full-flavor manifest only
        (app/src/full/AndroidManifest.xml) where the SSID feature actually lives, and
        limited to maxSdkVersion="32" so it is never requested on Android 13+ devices.

        If the SSID rule feature is not present in a build flavor it will never request
        background location at all.
    -->

    <!--
        QUERY_ALL_PACKAGES — Required for the per-app firewall feature.

        RethinkDNS is a per-app firewall and DNS filter. Its core function is to let
        users create allow/block rules for specific installed applications. To display
        the list of all installed apps (with icons, names, and traffic stats) and apply
        per-app rules, the app must enumerate every installed package on the device.
        Without QUERY_ALL_PACKAGES, Android 11+ only returns apps that explicitly list
        RethinkDNS in their <queries> element — making the per-app firewall non-functional.

        There is no narrower alternative: a static <queries> element cannot substitute
        for the dynamic full-package list used to build a real per-app firewall engine.

        Privacy mitigation: the package list is used ONLY to build the in-app firewall
        UI and apply rules inside the local VPN service. No package inventory is ever
        transmitted to any remote server.

        See: https://developer.android.com/training/package-visibility/use-cases
    -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <!-- Allows the app to perform actions across different users on the device. -->
    <uses-permission
        android:name="android.permission.INTERACT_ACROSS_USERS"
        tools:ignore="ProtectedPermissions" />

    <!--
        FIX #5 — Memory safety: re-enable GWP-ASan and upgrade MTE from off → async.

        ORIGINAL STATE:
            android:allowNativeHeapPointerTagging="false"
            android:gwpAsanMode="never"
            android:memtagMode="off"
        All three were set in response to issue #786 to work around pointer-tagging
        incompatibilities in libusque.so.

        FIX RATIONALE:

        (1) gwpAsanMode: "never" → removed (defaults to "always" on Android 14+).
            GWP-ASan is a SAMPLING-BASED heap-safety tool that is completely independent
            of MTE/pointer tagging.  It instruments malloc/free at the allocator level and
            has negligible overhead (~0% steady-state; ~1% when a sampled allocation is in
            flight).  There is NO reason related to libusque.so to disable it.  Re-enabling
            it catches heap-buffer-overflows and use-after-free bugs in production, which
            is especially important given the high-privilege nature of this VPN process.

        (2) memtagMode: "off" → "async".
            ASYNC mode has a ~93% per-occurrence detection rate for MTE tag mismatches
            and defers faulting until the next kernel boundary, so it has low runtime
            overhead suitable for production.  If libusque.so performs pointer arithmetic
            that violates MTE tag semantics it will now surface as a detectable crash
            rather than silent memory corruption.  If ASYNC proves incompatible with
            libusque.so on specific ARM9 devices, a targeted per-process override can be
            added (see the <process> tag in the manifest) rather than disabling MTE
            globally for the entire application.

        (3) allowNativeHeapPointerTagging: kept "false" for now.
            Hardware pointer tagging (HWASan-style top-byte tagging in the allocator) is
            distinct from MTE but also requires that native code does not mask or compare
            pointer addresses in ways that strip the tag bits.  Until libusque.so is
            audited or updated for pointer-tag safety this attribute stays false to
            avoid crashes.  Track in a follow-up issue.
    -->
    <!--
        FIX — Improper android backup configuration.

        android:allowBackup="false" disables Auto Backup entirely on Android 6–11.
        android:fullBackupContent points to backup_rules.xml (Android 6–11) which
        explicitly excludes all sensitive data domains as defence-in-depth.
        android:dataExtractionRules points to data_extraction_rules.xml (Android 12+)
        which excludes cloud backup and device-to-device transfers, and sets
        disableIfNoEncryptionCapabilities="true" so no backup runs on devices that
        cannot guarantee end-to-end encryption.

        RethinkDNS holds VPN/WireGuard private keys, DNS-over-HTTPS/TLS credentials,
        and blocklist configs in SharedPreferences and internal storage.  Leaking
        this data via Auto Backup to Google Drive or a device transfer would expose
        cryptographic key material.
    -->
    <application
        android:name=".RethinkDnsApplication"
        android:allowBackup="false"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:allowNativeHeapPointerTagging="false"
        android:memtagMode="async"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:ignore="ForegroundServicePermission">

        <activity
            android:name=".ui.PrepareVpnActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!--
            ExportedService suppressed: BraveVPNService MUST be exported so Android's
            VpnService framework can bind to it. The android:permission restricts binding
            to the system (protectionLevel="signature|privileged").
        -->
        <service
            android:name=".service.BraveVPNService"
            android:exported="true"
            android:foregroundServiceType="systemExempted|connectedDevice"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:stopWithTask="false"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <meta-data
                android:name="android.net.VpnService.SUPPORTS_ALWAYS_ON"
                android:value="true" />
            <meta-data
                android:name="android.net.VpnService.SUPPORTS_LOCKDOWN"
                android:value="true" />
        </service>
        <!--
            ExportedService suppressed: BraveTileService MUST be exported so the Quick
            Settings framework can bind to it. The android:permission restricts binding
            to the system tile framework (protectionLevel="signature|privileged").
        -->
        <service
            android:name=".service.BraveTileService"
            android:exported="true"
            android:icon="@drawable/shield_green"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            tools:ignore="ExportedService"
            tools:targetApi="24">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>

            <meta-data
                android:name="android.service.quicksettings.TOGGLEABLE_TILE"
                android:value="true" />
        </service>

    </application>

    <!--
        CAMERA permission — baseline removal for non-full-flavor builds.

        The CAMERA permission is injected automatically by the zxing QR-scanner AAR
        (com.journeyapps:zxing-android-embedded). zxing is a fullImplementation
        dependency present only in the full flavor. This tools:node="remove" ensures
        non-full builds (headless, website) never accidentally inherit CAMERA from a
        transitive dependency.

        The full-flavor manifest (app/src/full/AndroidManifest.xml) overrides this
        with an explicit declaration that documents the purpose and marks the camera
        hardware feature as android:required="false".
    -->
    <uses-permission
        android:name="android.permission.CAMERA"
        tools:node="remove" />

</manifest>
